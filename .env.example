# Required. Bearer token for all writes and the MCP endpoint.
# Generate one: openssl rand -hex 32
ARTIFACTS_API_KEY=

# Recommended. Public origin used in returned artifact URLs.
BASE_URL=http://localhost:3000

# Listen port.
PORT=3000

# ---------------------------------------------------------------------------
# Storage backend. Default `local` stores artifacts as plain files (see DATA_DIR).
# Set to `s3` to store them in any S3-compatible bucket instead — this is what
# lets artifacts survive a restart on hosts that reprovision a fresh container
# with no persistent disk (Fly Machines, Cloud Run, Heroku, some PaaS tiers).
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# local backend only. Where artifacts are stored (plain files). Only used when
# running node directly — the Docker image always stores data at /data (mount a
# volume).
DATA_DIR=./data

# s3 backend only. The bucket MUST be private — artifacts are always served
# through this app so their security headers/expiry/disable apply; a public
# bucket would bypass all of that. Works with AWS S3, Cloudflare R2, Backblaze
# B2, MinIO, DigitalOcean Spaces, Wasabi, and GCS (S3 interop).
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=my-artifacts
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=            # optional key prefix within the bucket, e.g. artifacts/
