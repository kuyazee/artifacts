# Required. Bootstrap admin bearer token — an all-scope, break-glass key that
# always works for writes, the MCP endpoint, and minting managed API keys.
# Day-to-day, create scoped managed keys (dashboard → API keys, or the CLI) for
# CLI/MCP clients instead of sharing this one. Generate: openssl rand -hex 32
ARTIFACTS_API_KEY=

# Optional. Seed the single admin account (dashboard login) on first boot. If
# unset, the dashboard shows a one-time "Create admin account" screen instead.
# ARTIFACTS_ADMIN_USERNAME=admin
# ARTIFACTS_ADMIN_PASSWORD=

# Recommended. Public origin used in returned artifact URLs. Also decides whether
# the session cookie is marked Secure (set an https:// origin in production).
BASE_URL=http://localhost:3000

# Listen port.
PORT=3000

# ---------------------------------------------------------------------------
# Storage backend. Default `local` stores artifacts as plain files (see DATA_DIR).
# Set to `s3` to store them in any S3-compatible bucket instead — this is what
# lets artifacts survive a restart on hosts that reprovision a fresh container
# with no persistent disk (Fly Machines, Cloud Run, Heroku, some PaaS tiers).
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# local backend only. Where artifacts are stored (plain files). Only used when
# running node directly — the Docker image always stores data at /data (mount a
# volume).
DATA_DIR=./data

# s3 backend only. The bucket MUST be private — artifacts are always served
# through this app so their security headers/expiry/disable apply; a public
# bucket would bypass all of that. Works with AWS S3, Cloudflare R2, Backblaze
# B2, MinIO, DigitalOcean Spaces, Wasabi, and GCS (S3 interop).
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=my-artifacts
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=            # optional key prefix within the bucket, e.g. artifacts/

# git backend only. Commits every change to a private git remote and rehydrates from it on
# boot. The remote MUST be private and there must be exactly one writer. GIT_REMOTE_URL must
# not contain credentials — use GIT_TOKEN (or GIT_USERNAME/GIT_PASSWORD) instead.
# GIT_REMOTE_URL=https://github.com/you/artifacts-store.git
# GIT_TOKEN=
# GIT_BRANCH=main
# GIT_WORK_DIR=./data/git
# GIT_AUTHOR_NAME=artifacts-host
# GIT_AUTHOR_EMAIL=artifacts@localhost

# postgres backend only. Blobs in a bytea column; survives a fresh container. Table is created
# on first boot. Set PGSSLMODE=disable for a local non-TLS server.
# DATABASE_URL=postgres://user:pass@host:5432/artifacts

# sqlite backend only. Single-file DB (built-in node:sqlite, no extra dep). Durable only if the
# file is on durable storage — like the local backend.
# SQLITE_PATH=./data/artifacts.db
