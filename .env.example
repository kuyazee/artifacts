# Required. Bearer token for all writes and the MCP endpoint.
# Generate one: openssl rand -hex 32
ARTIFACTS_API_KEY=

# Recommended. Public origin used in returned artifact URLs.
BASE_URL=http://localhost:3000

# Where artifacts are stored (plain files). Only used when running node
# directly — the Docker image always stores data at /data (mount a volume).
DATA_DIR=./data

# Listen port.
PORT=3000
