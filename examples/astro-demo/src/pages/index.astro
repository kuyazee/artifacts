---
const buildTime = new Date().toISOString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>Astro on artifacts</title>
  </head>
  <body>
    <main>
      <span class="badge">Astro</span>
      <h1>Hello from Astro</h1>
      <p>
        This page was built with <code>astro build</code> and deployed to a
        self-hosted <strong>artifacts</strong> instance as a zipped static site.
      </p>
      <p class="meta">Built at {buildTime}</p>
    </main>

    <style>
      /* Scoped styles land in a hashed /_astro/*.css file — proving that
         subpath-relative assets resolve correctly under /a/<slug>/. */
      :root {
        color-scheme: light dark;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: #0d1117;
        color: #e6edf3;
      }
      main {
        max-width: 34rem;
        padding: 2.5rem;
        text-align: center;
      }
      .badge {
        display: inline-block;
        padding: 0.2rem 0.7rem;
        border-radius: 999px;
        background: #ff5d01;
        color: #fff;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      h1 {
        margin: 1rem 0 0.5rem;
        font-size: 2.4rem;
      }
      p {
        line-height: 1.6;
        color: #9ba7b4;
      }
      code {
        background: #161b22;
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
        color: #e6edf3;
      }
      .meta {
        margin-top: 1.5rem;
        font-size: 0.85rem;
        opacity: 0.6;
      }
    </style>
  </body>
</html>
